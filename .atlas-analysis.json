  "keyFeatures": [
    "Edge detection using Sobel filters (pure NumPy, no OpenCV)",
    "Grayscale conversion with luminosity weighting",
    "Image upscaling and downscaling by integer factors",
    "Horizontal image flipping",
    "Arbitrary-angle image rotation with canvas expansion",
    "Color inversion (negative image)",
    "Contrast enhancement with percentile clipping",
    "RGB channel isolation (single or mixed channels)",
    "Transparency / alpha-channel addition",
    "Cross-platform setup scripts for Linux/macOS (shell) and Windows (PowerShell)"
  ],
